---
import Layout from '../layouts/Layout.astro';
import {getCollection} from "astro:content";
import BigCard from '../components/BigCard.astro';
const posts = await getCollection('data');

---

<Layout title="Index">
	<h1 class="text-5xl text-white text-center p-5">Data from a json file<br/>Cards from daisyui</h1>
	 <div class="grid grid-cols-3 border-2">
			{
				posts.map((p) => (
				<Fragment>
					<div class="border-2 card-lg shadow-amber-600">
					<div class="card-body">
		  				<figure><img src=`${p.data.img}`></figure>
		  				<h2 class="card-title">{p.data.title}</h2>
		  				<p>{p.data.description}</p>
					</div>
	  </div>
	  </Fragment>
				) 
			)
			}
	</div>
</Layout>

